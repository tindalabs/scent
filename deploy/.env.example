# Copy to .env and fill in. Do NOT commit .env.

# Domain that resolves to this VPS (A/AAAA record → server IP). Caddy provisions
# TLS for it automatically. Must be set before first `up` so the ACME challenge works.
SCENT_DOMAIN=api.example.com

# Email for Let's Encrypt expiry/issue notices.
ACME_EMAIL=you@example.com

# Postgres password. Generate a strong one, e.g. `openssl rand -hex 24`.
POSTGRES_PASSWORD=change-me

# Application secret key used to encrypt admin TOTP (2FA) secrets at rest. Generate
# with `openssl rand -hex 32`. Required to enable two-factor auth — if unset, the
# server still runs but 2FA enrollment is disabled. Keep it stable: rotating it makes
# existing enrolled secrets undecryptable (admins would re-enroll via recovery codes).
SCENT_SECRET_KEY=change-me

# Comma-separated browser origins allowed by CORS (e.g. https://app.example.com).
# Leave blank for an API-only deploy (server-to-server traffic sends no Origin).
CORS_ALLOWED_ORIGINS=

# Error tracking (Sentry). Unset = disabled (no events leave the box). The DSN is a
# write-only ingest key, not a secret of the cloud-token class — safe to paste here.
# IMPORTANT: create the Sentry project in the EU region (this is a PII-sensitive
# product); the server scrubs request bodies, cookies, and auth headers before sending
# (see deploy/README.md and docs/adr/0006-observability-sentry.md).
SENTRY_DSN=
# Environment tag shown in Sentry. Defaults to NODE_ENV (production here) if unset.
SENTRY_ENVIRONMENT=production
# Release identifier for grouping/regressions — set to the image tag or git SHA.
SENTRY_RELEASE=
# Performance-trace sample rate (0.0–1.0). Default 0 = errors only, no perf traces.
SENTRY_TRACES_SAMPLE_RATE=0

# Image tag to run. Default "latest"; pin to a commit SHA for reproducible deploys.
SCENT_IMAGE_TAG=latest

# Optional: path (inside the container) to a City-level GeoIP .mmdb to enable the
# impossible-travel risk signal. Must carry lat/lon (a Country DB won't work), e.g.
# MaxMind GeoLite2-City or DB-IP City Lite. Mount the file into scent-server AND
# scent-worker and point this at it. Left unset, the signal is simply not emitted.
# GEOIP_DB_PATH=/data/GeoLite2-City.mmdb

# Optional: IP-intelligence databases for the anonymizer/datacenter risk signal.
# GEOIP_ANONYMOUS_DB_PATH is authoritative (hosting/VPN/Tor/proxy flags — a paid
# MaxMind GeoIP2-Anonymous-IP or equivalent). GEOIP_ASN_DB_PATH (free GeoLite2-ASN)
# only enriches the reason text. Mount into scent-server AND scent-worker. Unset =
# anonymizer signal disabled.
# GEOIP_ANONYMOUS_DB_PATH=/data/GeoIP2-Anonymous-IP.mmdb
# GEOIP_ASN_DB_PATH=/data/GeoLite2-ASN.mmdb
