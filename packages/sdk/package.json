{
  "name": "@tindalabs/scent-sdk",
  "version": "0.1.0",
  "description": "Scent client SDK — browser fingerprinting, persistent identity tracking, and account linking for fraud prevention, bot detection, and behavioral analytics.",
  "keywords": [
    "fingerprinting",
    "identity",
    "fraud-detection",
    "bot-detection",
    "behavioral-analytics",
    "device-fingerprint",
    "session-tracking",
    "account-linking",
    "risk-scoring",
    "observability",
    "react",
    "vue"
  ],
  "license": "MIT",
  "author": "Isonimus",
  "homepage": "https://github.com/tindalabs/scent#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tindalabs/scent.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/tindalabs/scent/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/adapters/react.js",
      "types": "./dist/adapters/react.d.ts"
    },
    "./vue": {
      "import": "./dist/adapters/vue.js",
      "types": "./dist/adapters/vue.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@tindalabs/scent-engine": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "fake-indexeddb": "^6",
    "jsdom": "^25.0.0",
    "react": "^19.2.7",
    "typescript": "^5.8.0",
    "vitest": "^2.0.0",
    "vue": "^3.5.35"
  }
}
