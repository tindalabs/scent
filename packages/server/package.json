    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@tindalabs/scent-engine": "workspace:*",
    "cors": "^2.8.6",
    "express": "^4.18.0",
    "ioredis": "^5.11.1",
    "pino": "^9",
    "postgres": "^3.4.9",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6",
