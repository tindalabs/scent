{
  "name": "@tindalabs/scent-server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "license": "BSL-1.1",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "migrate": "tsx src/db/migrate-cli.ts",
    "create-project": "tsx src/scripts/create-project.ts",
    "create-admin": "tsx src/scripts/create-admin.ts",
    "set-org-plan": "tsx src/scripts/set-org-plan.ts",
    "worker": "tsx src/worker.ts",
    "worker:start": "node --import ./dist/instrument.js --import ./dist/tracing.js dist/worker.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@sentry/node": "^10.59.0",
    "@tindalabs/scent-engine": "workspace:*",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "maxmind": "^5.0.6",
    "otplib": "^12.0.1",
    "pino": "^9",
    "postgres": "^3.4.9",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "@types/supertest": "^6",
    "@vitest/coverage-v8": "^4.1.8",
    "supertest": "^7",
    "tsx": "^4.22.4",
    "typescript": "^5.8.0",
    "vitest": "^2.0.0"
  }
}
