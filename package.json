{
  "name": "scent",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "type-check": "turbo type-check",
    "lint": "turbo lint",
    "openapi:lint": "redocly lint docs/openapi.yaml",
    "bench": "pnpm --filter @tindalabs/scent-bench bench",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@redocly/cli": "^2.32.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.9.16",
    "typescript": "^5.8.0",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "vitest@<4.1.0": ">=4.1.0",
      "@vitest/coverage-v8@<4.1.0": ">=4.1.0",
      "ioredis": "5.11.1",
      "@grpc/grpc-js@>=1.14.0 <1.14.4": ">=1.14.4"
    }
  }
}
