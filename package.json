{
  "name": "scent",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "type-check": "turbo type-check",
    "lint": "turbo lint",
    "openapi:lint": "redocly lint docs/openapi.yaml",
    "bench": "pnpm --filter @tindalabs/scent-bench bench",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@redocly/cli": "^2.36.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.9.4",
    "turbo": "^2.10.2",
    "typescript": "^5.8.0",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "vitest@<4.1.0": ">=4.1.0",
      "@vitest/coverage-v8@<4.1.0": ">=4.1.0",
      "ioredis": "5.11.1",
      "@grpc/grpc-js@>=1.14.0 <1.14.4": ">=1.14.4",
      "esbuild@>=0.17.0 <0.28.1": ">=0.28.1",
      "ws@>=8.0.0 <8.21.0": ">=8.21.0",
      "form-data@>=4.0.0 <4.0.6": ">=4.0.6",
      "protobufjs@<=7.6.0": ">=7.6.1",
      "undici@<6.27.0": ">=6.27.0"
    }
  }
}
